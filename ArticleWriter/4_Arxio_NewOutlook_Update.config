{
  // Path relative to ArticleWriter/crawl_sources.py
  "working_folder": "__articles__/4_Arxio_NewOutlook_Update",

  // Article writer model (routed via OpenRouter when name contains "/")
  "openai_model": "anthropic/claude-opus-4.6",
  "openai_temperature": 0.2,

  // Thumbnail generation models (Nano Banana family)
  // Set true/false to indicate if a thumbnail should be generated with that model.
  "thumbnail_models": {
    "google/gemini-2.5-flash-image": true,
    "google/gemini-3-pro-image-preview": true
  },

  // Thumbnail generation attempts (prompt model + thumbnail model).
  // Prompts are cached per prompt_model within a single run.
  "thumbnail_attempts": [
    {
      "enabled": true,
      "prompt_model": "openai/gpt-5-mini",
      "thumbnail_model": "google/gemini-2.5-flash-image"
    },
    {
      "enabled": true,
      "prompt_model": "openai/gpt-5-mini",
      "thumbnail_model": "google/gemini-3-pro-image-preview"
    },
    {
      "enabled": true,
      "prompt_model": "anthropic/claude-3.5-sonnet",
      "thumbnail_model": "google/gemini-2.5-flash-image"
    },
    {
      "enabled": true,
      "prompt_model": "anthropic/claude-3.5-sonnet",
      "thumbnail_model": "google/gemini-3-pro-image-preview"
    }
  ]
}

